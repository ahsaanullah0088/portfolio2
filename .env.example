# ─────────────────────────────────────────────────────────────
#  Environment variables  (ALL OPTIONAL)
#  The site runs fine with NONE of these set.
#
#  ⚠️  This file IS committed to git — NEVER put real secrets here.
#  Put real values in `.env.local` (gitignored) instead:
#      cp .env.example .env.local
# ─────────────────────────────────────────────────────────────

# Contact form email delivery (via Resend — https://resend.com)
# Without this, the form falls back to opening the visitor's mail app.
# 1. Sign up free at resend.com  →  API Keys  →  Create
# 2. Paste the key below (starts with "re_")
RESEND_API_KEY=

# Where contact messages are sent. Defaults to your profile email
# (ahsaanu70@gmail.com) if left blank.
CONTACT_TO=

# The "from" address shown on received emails. For real delivery you must
# verify a domain in Resend; until then you can use their test sender:
#   Portfolio <onboarding@resend.dev>
CONTACT_FROM=

# ── Visitor counter (Upstash Redis) ───────────────────────────
# Powers the "views" count in the footer. Until set, the counter is hidden.
# Easiest setup: Vercel → Storage → create an Upstash Redis (KV) database and
# "Connect" it to this project — Vercel injects KV_REST_API_URL/TOKEN for you.
# Or grab them from https://console.upstash.com (Redis → REST API).
KV_REST_API_URL=
KV_REST_API_TOKEN=
# (Upstash-native names also work: UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN)
# Redis also stores every contact-form submission (read them at /inbox).

# ── Contact email via your own Gmail (Nodemailer) ─────────────
# Preferred over Resend. Uses a Gmail App Password (16 chars, not your login).
# Create at https://myaccount.google.com/apppasswords (requires 2-Step Verification).
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ── Inbox page password ───────────────────────────────────────
# Protects the /inbox admin page where stored messages are shown.
INBOX_SECRET=

# ── MongoDB (stores contact messages) ─────────────────────────
# From MongoDB Atlas → Connect → Drivers. If unset, falls back to Redis.
MONGODB_URI=
MONGODB_DB=portfolio
